{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": ["JWT_SECRET", "PORT", "DB_PATH", "PROVIDERS"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
