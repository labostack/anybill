# ─── Required ────────────────────────────────────────
# JWT signing key for admin authentication.
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=

# ─── Server ──────────────────────────────────────────
# Backend listening port.
PORT=3000

# CORS origins for local development (separate ports per SPA).
# In Docker, Caddy proxies everything through port 3000 so these are unused.
ADMIN_ORIGIN=http://localhost:3001
CHECKOUT_ORIGIN=http://localhost:3002

# ─── Database ────────────────────────────────────────
DB_PATH=./data/anybill.db
DB_DIR=./data

# ─── Auth ────────────────────────────────────────────
# JWT_EXPIRY=7d
# BCRYPT_ROUNDS=12

# ─── Link Encryption ─────────────────────────────────
# Separate key for encrypting checkout/portal links (AES-256-GCM).
# If not set, derived from JWT_SECRET automatically.
# Generate with: openssl rand -hex 32
# LINK_SECRET=

# ─── Providers ───────────────────────────────────────
# Directory containing provider plugin files (.ts/.js).
# Each file must default-export { name, provider }.
# PROVIDERS=./providers

# ─── Outgoing Webhooks ───────────────────────────────
# WEBHOOK_MAX_RETRIES=5
# WEBHOOK_RETRY_DELAYS_MS=10000,60000,300000,1800000,3600000
# WEBHOOK_RETRY_POLL_MS=15000
# WEBHOOK_RETRY_BATCH=20
# WEBHOOK_TIMEOUT_MS=10000
# WEBHOOK_MAX_BODY_LEN=2048
